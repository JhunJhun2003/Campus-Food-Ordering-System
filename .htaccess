<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /Campus-Food-Ordering-System/
    
    # Rewrite non-existent file/directory requests to Public/index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ Public/index.php [QSA,L]
</IfModule>
